# Anthropic API key (required for AI auto-trader)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram (required for Mirroly Live listener)
# Get API ID/Hash from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_CHANNEL=MirrorlyLive

# SSL CA certificate (for Cloudflare WARP or corporate proxy)
# Not needed on servers without proxy
#SSL_CERT_FILE=~/.config/certs/cloudflare-warp.pem
#REQUESTS_CA_BUNDLE=${SSL_CERT_FILE}
#NODE_EXTRA_CA_CERTS=${SSL_CERT_FILE}

# Backend API URL (used by docker-compose as NEXT_PUBLIC_API_URL build arg)
# - Local dev: defaults to http://localhost:8000 (override via .env.local)
# - Docker: injected at build time via docker-compose
API_URL=http://138.2.114.50:8000
